# Copy to .env.local and fill in. .env.local is git-ignored.

# Supabase (auth + saved trips). Find these at:
#   https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Claude (Anthropic) API — used SERVER-SIDE only, via api/claude.ts.
# Never expose this to the client. Vercel auto-loads non-VITE_ vars
# server-side; in local dev, run with `vercel dev` or load via your runner.
ANTHROPIC_API_KEY=
